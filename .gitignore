# Secrets
.env

# Rohdokumente (grosse Binärdateien — nicht in Git)
raw/

# Wiki-Vault (generierter Inhalt — OneDrive-Sync reicht)
wiki/

# Python
__pycache__/
*.pyc
*.pyo
.venv/
.uv/

# Windows
Thumbs.db
desktop.ini

# Ingest-Logs (lokal, kein Versionierungsbedarf)
logs/

# Design-Templates (proprietär, nicht öffentlich)
templates/*.potx
templates/*.pptx

# Generierte Präsentationen (außer .gitkeep)
output/*
!output/.gitkeep

# Temporäre Dateien
*.tmp
~$*
